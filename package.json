{
  "name": "nta-server-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "proto": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=esModuleInterop=true,forceLong=number,env=browser res/gtfs-realtime.proto res/nta.proto",
    "publish-gtfs": "bash scripts/gtfs/publish.sh"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.9.1",
    "adm-zip": "^0.5.16",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "ts-proto": "^2.11.8",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "@hono-rate-limiter/cloudflare": "^0.2.2",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3"
  }
}
